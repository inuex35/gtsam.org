fgz 1
style node_size=8.4mm factor_size=3.0mm label_sep=0.15pt label_font=small

xm1 = X_{k-1}
xk = X_k
xp1 = X_{k+1}
bm1 = b_{k-1}
bk = b_k
bp1 = b_{k+1}
u1 = u_{k-1}
u2 = u_k

variable xm1 (1.0, 0.7) color=gray!15
variable xk (3.8, 0.7) color=gray!15
variable xp1 (6.6, 0.7) color=gray!15
variable bm1 (1.0, 2.2) color=yellow!18
variable bk (3.8, 2.2) color=yellow!18
variable bp1 (6.6, 2.2) color=yellow!18

factor {xm1, xk, bm1, bk} (2.4, 1.45) shape=square color=green!18 label=u1 size=6.8mm font=scriptsize
factor {xk, xp1, bk, bp1} (5.2, 1.45) shape=square color=green!18 label=u2 size=6.8mm font=scriptsize
